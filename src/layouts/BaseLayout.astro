---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** When true, applies the extra bottom padding for detail pages */
  isDetail?: boolean;
}

const {
  title = "Fay — Product Designer",
  description = "Senior product designer working on cloud software, SaaS, and marketplaces.",
  isDetail = false,
} = Astro.props;
const socialImageUrl = Astro.site
  ? new URL("/preview-link.png", Astro.site).toString()
  : "/preview-link.png";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {isDetail && (
      <script is:inline>
        (function () {
          var DEFAULT_HEIGHT = 306;
          var padY = 43;
          var h = parseFloat(localStorage.getItem('main-content-height')) || DEFAULT_HEIGHT;
          var top = Math.max(padY, (window.innerHeight - h) / 2);
          document.documentElement.style.setProperty('--computed-main-top', Math.round(top) + 'px');
        })();
      </script>
    )}
  </head>
  <body>
    <div class:list={["page-wrapper", { "page-wrapper--detail": isDetail }]}>
      <main class:list={["page-content", { "page-content--detail": isDetail }]}>
        <slot />
      </main>
    </div>
    {!isDetail && (
      <script is:inline>
        (function () {
          function saveMainHeight() {
            var content = document.querySelector('.page-content');
            if (content) {
              localStorage.setItem(
                'main-content-height',
                Math.round(content.getBoundingClientRect().height)
              );
            }
          }
          if (document.readyState === 'complete') {
            saveMainHeight();
          } else {
            window.addEventListener('load', saveMainHeight);
          }
          window.addEventListener('resize', saveMainHeight);
        })();
      </script>
    )}
  </body>
</html>
