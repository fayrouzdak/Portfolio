---
import { Image } from "astro:assets";
import { resolveImage } from "../lib/images";
import type { Project } from "../data/types";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const thumbnailImages = await Promise.all(
  project.thumbnails.slice(0, 3).map(async (thumbnailPath) => {
    try {
      return await resolveImage(thumbnailPath);
    } catch {
      // Temporary fallback while thumbnails are being migrated to projectname-n.
      return resolveImage(`projects/${project.slug}/${project.slug}-1.png`);
    }
  })
);
---

<a href={`/projects/${project.slug}`} class="card">
  <div class="card__meta">
    <span class="card__icon" set:html={project.svg} />
    <p class="card__title">{project.title}</p>
    <p class="card__subtitle">
      at {project.company}
      {" /"} {project.period}
    </p>
  </div>

  <div class="card__image-wrap">
    {thumbnailImages.map((img, i) => (
      <Image
        src={img}
        alt={`${project.slug} thumbnail ${i + 1}`}
        widths={[420, 560, 700]}
        sizes="70px"
        quality={100}
        class="card__image"
      />
    ))}
  </div>
</a>

<style is:global>
  .card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    cursor: pointer;
    width: 186px;
    height: 182px;
    box-sizing: border-box;
    padding: 8px;
    border-radius: 6px;
    transition: background-color 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .card__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .card__icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
  }

  .card__icon :global(svg) {
    display: block;
  }

  .card__title {
    font-size: 13px;
    color: var(--color-text);
  }

  .card__subtitle {
    font-size: 13px;
    color: var(--color-text-muted);
  }

  .card__image-wrap {
    align-self: end;
    position: relative;
    width: 100%;
    height: 94px;
    margin-top: auto;
    margin-right: auto;
    margin-left: 0;
  }

  .card__image {
    display: flex;
    position: absolute;
    bottom: 0;
    width: 70px;
    height: 70px;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    box-sizing: border-box;
    
    border-radius: 4px;
    border-width: 2px;
    border-style: solid;
    border-color: #fff;
    box-shadow: 0 3px 3px 0 rgba(47, 41, 34, 0.08), 0 11px 8px 0 rgba(47, 41, 34, 0.08),
      0 4px 4px 0 rgba(47, 41, 34, 0.03), 0 1px 1px -0.5px rgba(47, 41, 34, 0.03),
      0 0 0 0.5px rgba(0, 0, 0, 0.1);
    transition: opacity 0.28s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.34s cubic-bezier(0.22, 1, 0.36, 1);
    object-fit: cover;
    background: #fff;
  }

  .card:hover {
    border-radius: 6px;
    background: #fafafa;
  }

  .card:hover .card__image {
    opacity: 0.96;
  }

  .card__image:nth-child(1) {
    left: 0;
    z-index: 1;
    transform: translateX(0) rotate(-3deg);
  }

  .card__image:nth-child(2) {
    left: 0;
    z-index: 2;
    transform: translateX(40px) rotate(0deg);
  }

  .card__image:nth-child(3) {
    left: 0;
    z-index: 3;
    transform: translateX(80px) rotate(3deg);
  }

  .card:hover .card__image:nth-child(1) {
    transform: translateX(0) rotate(0deg);
  }

  .card:hover .card__image:nth-child(2) {
    transform: translateX(50px) rotate(0deg);
  }

  .card:hover .card__image:nth-child(3) {
    transform: translateX(100px) rotate(0deg);
  }
</style>
