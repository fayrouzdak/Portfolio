---
import { Image } from "astro:assets";
import { resolveImage } from "../lib/images";
import type { SocialLink } from "../data/types";

interface Props {
  name: string;
  bio: string;
  avatar: string;
  socialLinks: SocialLink[];
}

const { name, bio, avatar, socialLinks } = Astro.props;
const avatarImage = await resolveImage(avatar);
---

<div class="bio">
  <div class="bio__left">
    <Image
      src={avatarImage}
      alt={name}
      width={28}
      height={28}
      class="bio__avatar"
    />
    <p class="bio__text">
      <span class="bio__name">Hi, I'm {name}.</span>
      {" "}{bio}
    </p>
  </div>

  <nav class="bio__links">
    {
      socialLinks.map((link) => (
        <a href={link.url} class="bio__link" target="_blank" rel="noopener noreferrer">
          {link.label}
        </a>
      ))
    }
  </nav>
</div>

<style>
  .bio {
    display: flex;
    align-items: flex-start;
    gap: 24px;
  }

  .bio__left {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    flex: 1;
  }

  .bio__avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
    margin-top: 1px;
  }

  .bio__text {
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-text);
  }

  .bio__name {
    font-weight: 400;
  }

  .bio__links {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    flex-shrink: 0;
  }

  .bio__link {
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-text);
    white-space: nowrap;
  }

  .bio__link:hover {
    color: var(--color-text-secondary);
  }
</style>
