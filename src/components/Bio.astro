---
import { Image } from "astro:assets";
import { resolveImage } from "../lib/images";
import type { SocialLink } from "../data/types";

interface Props {
  name: string;
  bio: string;
  avatar: string;
  socialLinks: SocialLink[];
}

const { name, bio, avatar, socialLinks } = Astro.props;
const avatarImage = await resolveImage(avatar);
---

<div class="bio">
  <div class="bio__left">
    <div class="bio__avatar-wrap">
      <Image
        src={avatarImage}
        alt={name}
        widths={[120, 240, 360]}
        sizes="30px"
        quality={95}
        class="bio__avatar"
      />
    </div>
    <p class="bio__text">
      <span class="bio__name">Hi, I'm {name}.</span>
      {" "}{bio}
    </p>
  </div>

  <nav class="bio__links">
    {
      socialLinks.map((link) => {
        const isMailto = link.url.startsWith("mailto:");
        return (
          <a
            href={link.url}
            class="bio__link"
            target={isMailto ? undefined : "_blank"}
            rel={isMailto ? undefined : "noopener noreferrer"}
          >
            {link.label}
          </a>
        );
      })
    }
  </nav>
</div>

<style is:global>
  .bio {
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }

  .bio__left {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    flex: 1;
  }

  .bio__avatar-wrap {
    position: relative;
    width: 30px;
    height: 30px;
    flex-shrink: 0;
  }

  .bio__avatar-wrap::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 4px;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.1);
    pointer-events: none;
  }

  .bio__avatar {
    width: 30px;
    height: 30px;
    border-radius: 4px;
    flex-shrink: 0;
    object-fit: cover;
  }

  .bio__text {
    font-size: 13px;
    color: var(--color-text);
  }

  .bio__name {
    font-weight: 400;
    color: var(--color-text-secondary);
  }

  .bio__links {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: flex-end;
    align-self: stretch;
    gap: 2px;
    flex-shrink: 0;
  }

  .bio__link {
    display: inline-block;
    font-size: 13px;
    color: var(--color-text);
    white-space: nowrap;
    border-bottom: 1px dashed transparent;
  }

  .bio__link:visited {
    color: var(--color-text);
  }

  .bio__link:hover,
  .bio__link:active {
    color: var(--color-text-secondary);
    border-bottom-color: #c5c5c5;
  }

  @media (max-width: 640px) {
    .bio {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .bio__left {
      flex-direction: column;
      align-items: flex-start;
      width: 100%;
      gap: 12px;
    }

    .bio__links {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: flex-start;
      justify-content: flex-start;
      align-self: flex-start;
      gap: 8px 12px;
    }
  }
</style>
