---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { portfolio } from "../../data/portfolio";
import { resolveImage } from "../../lib/images";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
  return portfolio.projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;

const showcaseImages = await Promise.all(
  project.showcaseImages.map((path) => resolveImage(path))
);
---

<BaseLayout
  title={`${project.role} at ${project.company} — Fay`}
  description={project.description[0]}
  isDetail={true}
>
  <div class="detail">
    <header class="detail__header">
      <a href="/" class="detail__back">
        <svg class="detail__back-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M4.10098 3.22611C4.27184 3.05525 4.27184 2.77824 4.10098 2.60739C3.93013 2.43653 3.65312 2.43653 3.48226 2.60739L1.35517 4.73448C1.07041 5.01924 1.07041 5.48092 1.35517 5.76568L3.48226 7.89276C3.65312 8.06361 3.93013 8.06361 4.10098 7.89276C4.27184 7.7219 4.27184 7.44493 4.10098 7.27407L2.51451 5.68758H11.2292C11.6319 5.68758 11.9583 6.01401 11.9583 6.41675V9.47925C11.9583 9.88198 11.6319 10.2084 11.2292 10.2084H6.85417C6.61255 10.2084 6.41667 10.4043 6.41667 10.6459C6.41667 10.8875 6.61255 11.0834 6.85417 11.0834H11.2292C12.1151 11.0834 12.8333 10.3652 12.8333 9.47925V6.41675C12.8333 5.53079 12.1151 4.81258 11.2292 4.81258H2.51451L4.10098 3.22611Z" fill="currentColor"/>
        </svg> Back
      </a>
      <span class="detail__company">
        {project.companyFull ?? project.company} / {project.period}
      </span>
    </header>

    <section class="detail__body">
      <div class="detail__role-heading">
        <div class="detail__role-label">Role overview</div>
        <h1 class="detail__role-title">{project.role}</h1>
      </div>

      <div class="detail__description">
        {project.description.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </section>

    {
      showcaseImages.length > 0 && (
        <div class="detail__showcase">
          {showcaseImages.map((img, i) => (
            <div class="detail__showcase-item">
              <Image
                src={img}
                alt={`${project.company} project screenshot ${i + 1}`}
                widths={[550, 1100, 1650]}
                sizes="(max-width: 640px) calc(100vw - 40px), 550px"
                quality={95}
                class="detail__showcase-image"
                loading={i === 0 ? "eager" : "lazy"}
              />
            </div>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  .detail {
    display: flex;
    flex-direction: column;
  }

  /* ─── Header ─────────────────────────────── */
  .detail__header {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 24px;
    margin-bottom: 20px;
  }

  .detail__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #949494;
    transition: color 0.15s ease;
  }

  .detail__back:hover {
    color: #000000;
  }

  .detail__back-arrow {
    flex-shrink: 0;
  }

  .detail__back-arrow path {
    transition: fill 0.15s ease;
  }

  .detail__company {
    margin-left: auto;
    font-size: 13px;
    color: #949494;
    text-align: right;
  }

  /* ─── Body ───────────────────────────────── */
  .detail__body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 28px;
  }

  .detail__role-heading {
    display: flex;
    flex-direction: row;
    gap: 8px;
    margin-bottom: 8px;
  }

  .detail__role-label {
    font-size: 13px;
    color: #656565;
  }

  .detail__role-title {
    font-size: 13px;
    font-weight: 400;
    color: #000000;
  }

  .detail__description {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .detail__description p {
    font-size: 13px;
    color: var(--color-text-secondary);
  }

  /* ─── Showcase ───────────────────────────── */
  .detail__showcase {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .detail__showcase-item {
    border-radius: 4px;
    overflow: hidden;
    border: 2px solid #FFF;
    background: #FFF;
    box-shadow: 0 0 0 0.5px rgba(0, 0, 0, 0.10);
  }

  .detail__showcase-image {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
