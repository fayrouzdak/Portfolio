---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WritingAsciiGif from "../../components/WritingAsciiGif.astro";
import { article } from "../../data/writing";
---

<BaseLayout title="How AI made me a builder — Fay" description="Articles and writing by Fay" isDetail={true}>
  <div class="writing">
    <header class="writing__header">
      <a href="/" class="writing__back">
        <svg class="writing__back-arrow" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 14 14" fill="none">
          <path d="M4.10098 3.22611C4.27184 3.05525 4.27184 2.77824 4.10098 2.60739C3.93013 2.43653 3.65312 2.43653 3.48226 2.60739L1.35517 4.73448C1.07041 5.01924 1.07041 5.48092 1.35517 5.76568L3.48226 7.89276C3.65312 8.06361 3.93013 8.06361 4.10098 7.89276C4.27184 7.7219 4.27184 7.44493 4.10098 7.27407L2.51451 5.68758H11.2292C11.6319 5.68758 11.9583 6.01401 11.9583 6.41675V9.47925C11.9583 9.88198 11.6319 10.2084 11.2292 10.2084H6.85417C6.61255 10.2084 6.41667 10.4043 6.41667 10.6459C6.41667 10.8875 6.61255 11.0834 6.85417 11.0834H11.2292C12.1151 11.0834 12.8333 10.3652 12.8333 9.47925V6.41675C12.8333 5.53079 12.1151 4.81258 11.2292 4.81258H2.51451L4.10098 3.22611Z" fill="currentColor"/>
        </svg> Back
      </a>
      <span class="writing__meta">Apr 2026</span>
    </header>

    <section class="writing__intro" aria-label="Article heading">
      <h1 class="writing__intro-title">{article.title}</h1>
    </section>

    <WritingAsciiGif />

    <article class="writing__article" aria-label="Article body">
      {article.sections.map((section) => (
        <section class="writing__section">
          <h2 class="writing__section-title">{section.heading}</h2>
          {section.paragraphs.map((paragraph) => (
            <p set:html={paragraph} />
          ))}
        </section>
      ))}
    </article>
  </div>
</BaseLayout>

<style>
  .writing {
    display: flex;
    flex-direction: column;
    width: 100%;
    min-width: 0;
  }

  .writing__header {
    display: flex;
    align-items: flex-start;
    gap: 26px;
    margin-bottom: 22px;
  }

  .writing__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: #949494;
    transition: color 0.15s ease;
  }

  .writing__back:hover {
    color: #000000;
  }

  .writing__meta {
    margin-left: auto;
    font-size: 14px;
    color: #949494;
    text-align: right;
  }

  .writing__intro {
    display: flex;
    flex-direction: column;
    gap: 9px;
    margin-bottom: 24px;
  }

  .writing__intro-title {
    font-size: 14px;
    font-weight: 400;
    color: #000000;
  }

  .writing__article {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .writing__section {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .writing__section-title {
    font-size: 14px;
    font-weight: 400;
    color: #000000;
  }

  .writing__article p {
    font-size: 14px;
    color: #656565;
    letter-spacing: 0.01em;
  }
</style>
